PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/bhoomichain

# JWT
JWT_SECRET=bhoomichain_production_secret_key_change_me
JWT_EXPIRES_IN=24h

# Hyperledger Fabric Gateway
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_PEER_HOST_ALIAS=peer0.revenueorg.bhoomichain.com
FABRIC_MSP_ID=RevenueOrgMSP
FABRIC_CHANNEL_NAME=bhoomichannel
FABRIC_CHAINCODE_NAME=landregistry

# Fabric CA (Production-Grade User Enrollment)
FABRIC_CA_URL=https://localhost:7054
FABRIC_CA_NAME=ca-revenue
FABRIC_CA_ADMIN_USER=admin
FABRIC_CA_ADMIN_PW=adminpw
FABRIC_CA_TLS_CERT_PATH=../blockchain-network/crypto-config/peerOrganizations/revenueorg.bhoomichain.com/ca/ca.revenueorg.bhoomichain.com-cert.pem

# Crypto Material Paths
FABRIC_TLS_CERT_PATH=../blockchain-network/crypto-config/peerOrganizations/revenueorg.bhoomichain.com/peers/peer0.revenueorg.bhoomichain.com/tls/ca.crt

# IPFS (Real Document Storage)
IPFS_RPC_URL=http://127.0.0.1:5001
